LIBRARY ieee;
USE ieee.std_logic_1164.ALL;
USE ieee.numeric_std.ALL;

ENTITY Lab3_tb IS
END Lab3_tb;

ARCHITECTURE behavior OF Lab3_tb IS

    -- Component under test
    COMPONENT Lab3
        PORT(
            S1     : IN  STD_LOGIC;
            S0     : IN  STD_LOGIC;
            CLK    : IN  STD_LOGIC;
            InputA : IN  STD_LOGIC_VECTOR(3 DOWNTO 0);
            InputB : IN  STD_LOGIC_VECTOR(3 DOWNTO 0);
            OE     : OUT STD_LOGIC_VECTOR(7 DOWNTO 0)
        );
    END COMPONENT;

    SIGNAL CLK     : STD_LOGIC := '0';
    SIGNAL S1, S0  : STD_LOGIC := '0';
    SIGNAL InputA  : STD_LOGIC_VECTOR(3 DOWNTO 0) := (others => '0');
    SIGNAL InputB  : STD_LOGIC_VECTOR(3 DOWNTO 0) := (others => '0');
    SIGNAL OE      : STD_LOGIC_VECTOR(7 DOWNTO 0);

    CONSTANT CLK_PERIOD : time := 20 ns;

BEGIN

    -- Instantiate DUT
    UUT : Lab3
        PORT MAP (
            S1 => S1,
            S0 => S0,
            CLK => CLK,
            InputA => InputA,
            InputB => InputB,
            OE => OE
        );

    -- Clock process
    CLK_process : PROCESS
    BEGIN
        CLK <= '0';
        WAIT FOR CLK_PERIOD/2;
        CLK <= '1';
        WAIT FOR CLK_PERIOD/2;
    END PROCESS;

    -- Stimulus process
    stim_proc : PROCESS
        PROCEDURE DoMultiply(
            constant A : STD_LOGIC_VECTOR(3 DOWNTO 0);
            constant B : STD_LOGIC_VECTOR(3 DOWNTO 0)
        ) IS
        BEGIN
            -- Nạp giá trị đầu vào
            InputA <= A;
            InputB <= B;

            -- LOAD phase (1 clock)
            S1 <= '0'; S0 <= '1';  -- S1S0 = 01 => LOAD
            WAIT FOR CLK_PERIOD;
            
            -- SHIFT-ADD phase (4 clocks)
            S1 <= '1'; S0 <= '0';  -- S1S0 = 10 => SHIFT
            WAIT FOR 4 * CLK_PERIOD;
            
            -- HOLD result
            S1 <= '0'; S0 <= '0';  -- S1S0 = 00 => HOLD
            WAIT FOR CLK_PERIOD;

            REPORT "A=" & INTEGER'IMAGE(to_integer(unsigned(A))) &
                   "  B=" & INTEGER'IMAGE(to_integer(unsigned(B))) &
                   "  => OE=" & INTEGER'IMAGE(to_integer(unsigned(OE))) &
                   "  (binary " & std_logic_vector'(OE)'IMAGE & ")";
            WAIT FOR CLK_PERIOD;
        END PROCEDURE;

    BEGIN
        WAIT FOR 50 ns; -- reset settle

        -- Test các cặp giá trị
        DoMultiply("0011", "0101"); -- 3x5 = 15
        DoMultiply("0111", "0010"); -- 7x2 = 14
        DoMultiply("0100", "0110"); -- 4x6 = 24
        DoMultiply("1010", "0011"); -- 10x3 = 30
        DoMultiply("1111", "1111"); -- 15x15 = 225

        WAIT;
    END PROCESS;

END behavior;
